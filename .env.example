# Upstox Credentials
# Get these from: https://upstox.com/developer/settings
# DO NOT commit .env file - only commit this .env.example
UPSTOX_API_KEY=your_api_key_here
UPSTOX_API_SECRET=your_api_secret_here
UPSTOX_ACCESS_TOKEN=your_access_token_here

# Server Configuration
HOST=0.0.0.0
PORT=8080
FLASK_ENV=production
DEBUG=false

# WebSocket Settings
WS_PING_INTERVAL=30
WS_PING_TIMEOUT=10
WS_BATCH_SIZE=50
WS_MAX_BUFFER=10000
WS_RECONNECT_DELAY=5
WS_MAX_RECONNECT_ATTEMPTS=10

# Performance
REQUEST_TIMEOUT=10
CACHE_TTL=5

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/algofo.log

# MilesWeb VPS Settings
SELF_PING_ENABLED=true
SELF_PING_INTERVAL=480
VPS_URL=http://your_vps_ip:8080
